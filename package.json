{
  "name": "devcut",
  "displayName": "DevCut — Get Paid for Waiting",
  "description": "Shows a sponsored line in your status bar while you wait on builds, installs, and tests. You get a share of the revenue.",
  "version": "0.1.2",
  "publisher": "gouravgujariya",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/gouravgujariya/waitwage"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devcut.activate",
        "title": "DevCut: Activate with Invite Code"
      },
      {
        "command": "devcut.showEarnings",
        "title": "DevCut: Show My Earnings"
      },
      {
        "command": "devcut.syncEarnings",
        "title": "DevCut: Sync Earnings from Server"
      },
      {
        "command": "devcut.setUpiId",
        "title": "DevCut: Set Payout UPI ID"
      },
      {
        "command": "devcut.withdraw",
        "title": "DevCut: Withdraw Earnings to UPI"
      },
      {
        "command": "devcut.createTeam",
        "title": "DevCut: Create Team Pool"
      },
      {
        "command": "devcut.joinTeam",
        "title": "DevCut: Join Team Pool"
      },
      {
        "command": "devcut.showTeam",
        "title": "DevCut: Show Team Leaderboard"
      },
      {
        "command": "devcut.login",
        "title": "DevCut: Sign In (returning user)"
      },
      {
        "command": "devcut.openWebsite",
        "title": "DevCut: Open Website / Get Invite Code"
      },
      {
        "command": "devcut.openSettings",
        "title": "DevCut: Open Settings"
      },
      {
        "command": "devcut.testAd",
        "title": "DevCut: Test Ad (10s demo)"
      }
    ],
    "configuration": {
      "title": "DevCut",
      "properties": {
        "devcut.backendUrl": {
          "type": "string",
          "default": "https://waitwage-production.up.railway.app",
          "description": "Backend URL that serves the current sponsor line and records impressions."
        },
        "devcut.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show sponsored status bar messages during long-running tasks."
        },
        "devcut.minTaskSeconds": {
          "type": "number",
          "default": 3,
          "description": "Minimum task duration (seconds) before a sponsored line is shown. Avoids flicker on instant tasks."
        },
        "devcut.adRotationSeconds": {
          "type": "number",
          "default": 30,
          "description": "Seconds between ad rotations during a long-running task. Each rotation is a new impression."
        },
        "devcut.earningsFlashSeconds": {
          "type": "number",
          "default": 4,
          "description": "Seconds the post-task 'Earned ₹X.XX this build' message stays visible before hiding."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.24.0"
  }
}
